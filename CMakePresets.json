{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 0
  },
  "configurePresets": [
    {
      "name": "desktop-base",
      "description": "Build for host operating system using vcpkg",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/desktop",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_CXX_STANDARD": "17",
        "CMAKE_C_STANDARD": "99",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "desktop",
      "displayName": "Windows Desktop (Native)",
      "inherits": "desktop-base",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "$env{MSVC_COMPILER_ROOT}/cl.exe",
        "CMAKE_CXX_COMPILER": "$env{MSVC_COMPILER_ROOT}/cl.exe",
        "VCPKG_MANIFEST_FEATURES": "demos;unit-tests"
      }
    },
    {
      "name": "github-actions-ubuntu",
      "displayName": "Run on GitHub Actions",
      "inherits": "desktop-base",
      "cacheVariables": {
        "CMAKE_MAKE_PROGRAM": "/usr/bin/ninja",
        "VCPKG_MANIFEST_FEATURES": "unit-tests"
      }
    },
    {
      "name": "web",
      "displayName": "WebAssembly (Emscripten)",
      "description": "Build for the web using Emscripten",
      "binaryDir": "${sourceDir}/build/web",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
        "CMAKE_CXX_STANDARD": "17",
        "CMAKE_C_STANDARD": "99",
        "VCPKG_TARGET_TRIPLET": "wasm32-emscripten",
        "VCPKG_MANIFEST_FEATURES": "demos"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "desktop-build",
      "configurePreset": "desktop"
    },
    {
      "name": "web-build",
      "configurePreset": "web"
    },
    {
      "name": "github-actions-ubuntu-build",
      "configurePreset": "github-actions-ubuntu"
    }
  ],
  "testPresets": [
    {
      "name": "tests-preset-base",
      "hidden": true,
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      }
    },
    {
      "name": "unit-tests-desktop",
      "configurePreset": "desktop",
      "inherits": "tests-preset-base"
    },
    {
      "name": "unit-tests-github-actions",
      "configurePreset": "github-actions-ubuntu",
      "inherits": "tests-preset-base"
    }
  ]
}