{
  "name": "game-math-gym",
  "version": "0.1.0",
  "dependencies": [
    "assimp",
    {
      "name": "glad",
      "features": [
        "gl-api-15",
        "gl-api-21",
        "gl-api-31",
        "gl-api-33"
      ]
    },
    {
      "name": "imgui",
      "features": [
        "opengl3-binding",
        "sdl3-binding"
      ]
    },
    "sdl3",
    "stb"
  ],
  "overrides": [
    {
      "name": "sdl3",
      "version": "3.4.2"
    },
    {
      "name": "imgui",
      "version": "1.92.8"
    },
    {
      "name": "glad",
      "version": "0.1.36"
    },
    {
      "name": "assimp",
      "version": "6.0.4"
    }
  ]
}
